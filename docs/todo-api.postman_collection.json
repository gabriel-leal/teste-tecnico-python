{
  "info": {
    "_postman_id": "b771cf78-6f2f-4a1b-a929-5dd38f64a8c5",
    "name": "To-Do API",
    "description": "Collection para testar a API de tarefas. Use a variável baseUrl para apontar para o servidor e taskId para buscar, atualizar ou excluir uma tarefa criada.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "00000000-0000-0000-0000-000000000000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Verificar API",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Verifica se a API está rodando corretamente.",
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Criar tarefa",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Cria uma nova tarefa. Campos: title obrigatório, description opcional, status opcional. Status disponíveis: Pendente, Em andamento, Concluída.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Estudar FastAPI\",\n  \"description\": \"Criar testes automatizados\",\n  \"status\": \"Pendente\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "    pm.collectionVariables.set(\"taskId\", body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Listar tarefas",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Lista todas as tarefas que não foram excluídas.",
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Resposta é uma lista\", function () {",
                  "    pm.expect(pm.response.json()).to.be.an(\"array\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Listar tarefas com filtros",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Lista tarefas usando filtros opcionais por título e status.",
            "url": {
              "raw": "{{baseUrl}}/tasks?title=FastAPI&status=Pendente",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks"
              ],
              "query": [
                {
                  "key": "title",
                  "value": "FastAPI",
                  "description": "Busca parcial pelo título."
                },
                {
                  "key": "status",
                  "value": "Pendente",
                  "description": "Status disponíveis: Pendente, Em andamento, Concluída."
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Buscar tarefa por ID",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Busca uma tarefa específica pelo UUID salvo na variável taskId.",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Atualizar tarefa",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Atualiza parcialmente uma tarefa. Todos os campos do body são opcionais.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tarefa atualizada\",\n  \"description\": \"Finalizar a collection do Postman\",\n  \"status\": \"Concluída\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Excluir tarefa",
          "request": {
            "method": "DELETE",
            "header": [],
            "description": "Realiza exclusão lógica da tarefa salva em taskId.",
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tasks",
                "{{taskId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 204\", function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    }
  ]
}
